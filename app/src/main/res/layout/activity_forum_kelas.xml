<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:ignore="all">

    <LinearLayout
        android:id="@+id/header_forum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back_forum"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:padding="12dp"
            app:tint="#202124" />

        <TextView
            android:id="@+id/tv_forum_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Forum Kelas"
            android:textColor="#202124"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_selector_forum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E8EAED"
        app:layout_constraintTop_toBottomOf="@id/header_forum">

        <TextView
            android:id="@+id/tv_forum_kelas_selector"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Pilih Kelas ▼"
            android:textColor="#0056D2"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:background="@android:color/white"
            android:visibility="gone" />
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_forum"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/card_selector_forum"
        app:layout_constraintBottom_toTopOf="@id/input_container_forum" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/input_container_forum"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E8EAED"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/input_bar_forum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp">

            <EditText
                android:id="@+id/et_forum_pesan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Tulis pesan ke kelas..."
                android:inputType="textMultiLine"
                android:maxLines="4"
                android:paddingVertical="12dp"
                android:paddingHorizontal="20dp"
                android:textSize="14sp"
                android:textColor="#202124"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_margin="4dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0D47A1">

                <ImageView
                    android:id="@+id/iv_forum_kirim"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_send"
                    android:padding="12dp"
                    app:tint="@android:color/white" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        tools:ignore="MissingConstraints">
        <include layout="@layout/layout_arrow" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>