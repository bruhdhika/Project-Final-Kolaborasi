<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".StrukDispensasi">

    <ImageView
        android:id="@+id/iv_back_arrow"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_arrow_back"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        app:tint="#202124"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Tombol Kembali" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/iv_header"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_check_circle"
            app:tint="#0F9D58"
            android:layout_marginBottom="16dp"
            android:contentDescription="Header Background"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Struk Dispensasi"
            android:textColor="#202124"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rincian dispensasi telah dicatat."
            android:textColor="#5F6368"
            android:layout_marginTop="4dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_struk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#E8EAED"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rincian Pengajuan"
                    android:textStyle="bold"
                    android:textColor="#202124"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tv_struk_nama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nama : Loading..."
                    android:textColor="#202124"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tv_struk_kelas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kelas : Loading..."
                    android:textColor="#202124"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tv_struk_alasan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alasan Dispensasi : Loading..."
                    android:textColor="#202124"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tv_struk_wali"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Wali Kelas : Loading..."
                    android:textColor="#202124"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_struk_status"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Sudah Menghubungi Wali Kelas"
                    android:textColor="#0F9D58"
                    android:background="#E6F4EA"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8EAED"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/btn_kembali_home"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="Kembali Ke Home Page"
                    android:textColor="#0056D2"
                    android:textStyle="bold"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btn_download"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Download Struk"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="#5F6368"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>