<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_wali"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_card_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4CAF50">

        <!-- Foto profil guru (di-load via Glide dari photoUrl Firestore) -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/iv_guru_foto"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/image_3"
            app:civ_border_width="2dp"
            app:civ_border_color="#FFFFFF"
            android:layout_marginEnd="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Nama guru -->
        <TextView
            android:id="@+id/tv_guru_nama"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nama Guru"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginStart="36dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_guru_foto"
            app:layout_constraintBottom_toTopOf="@id/tv_guru_kelas"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- Nama kelas yang dipegang guru -->
        <TextView
            android:id="@+id/tv_guru_kelas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nama Kelas"
            android:textColor="#1A1A1A"
            android:textSize="13sp"
            android:fontFamily="serif"
            android:layout_marginStart="36dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_guru_foto"
            app:layout_constraintTop_toBottomOf="@id/tv_guru_nama"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
