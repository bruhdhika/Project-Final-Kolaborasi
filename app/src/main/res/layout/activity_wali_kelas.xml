<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".WaliKelasActivity">

    <!-- Header background — SAMA seperti sebelumnya -->
    <ImageView
        android:id="@+id/iv_header"
        android:layout_width="1dp"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:src="@drawable/matematika"
        android:contentDescription="Header Background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Tombol back — SAMA seperti sebelumnya -->
    <ImageView
        android:id="@+id/iv_back_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/black"
        android:padding="16dp"
        android:layout_marginTop="32dp"
        android:contentDescription="Tombol Kembali"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Judul — SAMA seperti sebelumnya -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wali Kelas"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintBottom_toBottomOf="@id/iv_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_header" />

    <!-- Background putih melengkung — SAMA seperti sebelumnya -->
    <View
        android:id="@+id/view_white_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_white_curved_top"
        android:layout_marginTop="130dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Search bar — SAMA seperti sebelumnya, sekarang benar-benar berfungsi -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_search_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/et_search_wali"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_edittext_grey"
            android:hint="Cari Wali Kelas"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="48dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/search"
            app:tint="#808080"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="@id/et_search_wali"
            app:layout_constraintEnd_toEndOf="@id/et_search_wali"
            app:layout_constraintTop_toTopOf="@id/et_search_wali" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ProgressBar: tampil saat loading data dari Firestore -->
    <ProgressBar
        android:id="@+id/pb_wali_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/cl_search_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Empty state: tampil jika tidak ada guru terdaftar -->
    <TextView
        android:id="@+id/tv_wali_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Belum ada wali kelas terdaftar."
        android:gravity="center"
        android:textColor="#9E9E9E"
        android:textSize="15sp"
        android:visibility="gone"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/cl_search_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- RecyclerView: list guru dinamis dari Firestore -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_wali_kelas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="32dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/cl_search_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include layout="@layout/layout_arrow" />

</androidx.constraintlayout.widget.ConstraintLayout>
