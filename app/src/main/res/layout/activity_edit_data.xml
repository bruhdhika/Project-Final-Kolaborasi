<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Profil"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="32dp"/>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/edit_img_avatar"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/image_3"
                app:civ_border_width="2dp"
                app:civ_border_color="#EEEEEE"/>
            <ImageButton
                android:id="@+id/btn_change_photo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignBottom="@id/edit_img_avatar"
                android:layout_alignEnd="@id/edit_img_avatar"
                android:background="@drawable/bg_button_blue_gradient"
                android:src="@drawable/edit"
                app:tint="#FFFFFF"
                android:padding="6dp"/>
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Pengguna"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_edit_nama"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_gray"
            android:paddingHorizontal="16dp"
            android:hint="Masukkan nama baru"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Baru"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_edit_email"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_gray"
            android:paddingHorizontal="16dp"
            android:hint="contoh@gmail.com"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ganti Password"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_edit_password"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_gray"
            android:paddingHorizontal="16dp"
            android:hint="Isi jika ingin ganti"
            android:inputType="textPassword"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/layout_konfirmasi_pass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Konfirmasi Password Baru"
                android:textStyle="bold"
                android:textColor="#FF0000"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_confirm_password"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input_gray"
                android:paddingHorizontal="16dp"
                android:inputType="textPassword"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btn_simpan_perubahan"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Simpan Perubahan"
            android:background="@drawable/bg_button_blue_gradient"
            app:backgroundTint="@null"
            android:textColor="#FFFFFF"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>