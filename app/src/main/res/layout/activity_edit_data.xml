<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">

            <include
                layout="@layout/layout_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:layout_marginStart="-16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit Profil"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#202124"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="32dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/edit_img_avatar"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/image_3"
                app:civ_border_width="2dp"
                app:civ_border_color="#E8EAED"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/btn_change_photo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignBottom="@id/edit_img_avatar"
                android:layout_alignEnd="@id/edit_img_avatar"
                android:src="@drawable/edit"
                app:civ_circle_background_color="#0056D2"
                app:tint="#FFFFFF"
                android:padding="6dp"/>
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Pengguna"
            android:textStyle="bold"
            android:textColor="#3C4043"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_edit_nama"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_white"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:hint="Masukkan nama baru"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Baru"
            android:textStyle="bold"
            android:textColor="#3C4043"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_edit_email"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_white"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:inputType="textEmailAddress"
            android:hint="contoh@gmail.com"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ganti Password"
            android:textStyle="bold"
            android:textColor="#3C4043"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/et_edit_password"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input_white"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:hint="Isi jika ingin ganti sandi"
            android:inputType="textPassword"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/layout_konfirmasi_pass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Konfirmasi Password Baru"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/et_confirm_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_white"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:inputType="textPassword"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_simpan_perubahan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Simpan Perubahan"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"
            app:backgroundTint="#0056D2"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>