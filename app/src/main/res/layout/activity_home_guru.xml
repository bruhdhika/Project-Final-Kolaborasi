<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">



    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Header biru gradient guru -->
        <ImageView
            android:id="@+id/iv_header"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/matematika"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Icon menu (drawer) -->
        <ImageView
            android:id="@+id/iv_header_icon"
            android:layout_width="30dp"
            android:layout_height="34dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="60dp"
            android:src="@drawable/menu"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Badge GURU -->
        <TextView
            android:id="@+id/tv_badge_guru"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👨‍🏫 GURU"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="#331565C0"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="48dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Sapaan guru -->
        <TextView
            android:id="@+id/tv_guru_greeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Halo, Guru"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="60dp"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_badge_guru" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Kelola kelas dan pantau siswa kamu!"
            android:textColor="#CCE3F2FD"
            android:textSize="14sp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="60dp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_guru_greeting" />

        <!-- Area putih melengkung + RecyclerView -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="150dp"
            android:background="@drawable/bg_white_curved_top"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelas Saya"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="16dp" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/tv_empty_kelas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Belum ada kelas.\nTekan tombol + untuk membuat kelas baru."
                    android:gravity="center"
                    android:textColor="#9E9E9E"
                    android:textSize="15sp"
                    android:visibility="visible"
                    android:paddingVertical="40dp" />

                <!-- RecyclerView list kelas -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_kelas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>
        </ScrollView>

        <!-- FAB Tambah Kelas -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_tambah_kelas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="32dp"
            android:src="@android:drawable/ic_input_add"
            app:backgroundTint="#1565C0"
            app:tint="@android:color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <include
            layout="@layout/layout_arrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Drawer menu (sama seperti HomeActivity) -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        app:menu="@menu/menu_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
