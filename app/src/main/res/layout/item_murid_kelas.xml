<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_murid"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Nama + Kelas -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/image_3" android:layout_marginEnd="12dp" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tv_murid_nama" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Nama Murid"
                    android:textSize="16sp" android:textStyle="bold" android:textColor="#212121" />
                <TextView android:id="@+id/tv_murid_kelas" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="XI RPL 1"
                    android:textSize="12sp" android:textColor="#757575" />
            </LinearLayout>

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_arrow_back" android:rotation="180" app:tint="#BDBDBD" />
        </LinearLayout>

        <!-- Stat badges horizontal -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:weightSum="3">

            <TextView android:id="@+id/tv_stat_terlambat"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Terlambat: 0x" android:textSize="11sp" android:textColor="#E65100"
                android:background="#FFF3E0" android:padding="6dp" android:gravity="center"
                android:layout_marginEnd="4dp" />

            <TextView android:id="@+id/tv_stat_absen"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Tdk Hadir: 0x" android:textSize="11sp" android:textColor="#B71C1C"
                android:background="#FFEBEE" android:padding="6dp" android:gravity="center"
                android:layout_marginEnd="4dp" />

            <TextView android:id="@+id/tv_stat_dispen"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Dispen: 0x" android:textSize="11sp" android:textColor="#1565C0"
                android:background="#E3F2FD" android:padding="6dp" android:gravity="center" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
