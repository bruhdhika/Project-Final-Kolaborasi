<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:gravity="start" android:padding="4dp">
    <TextView android:id="@+id/tv_chat_sender"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Guru" android:textSize="11sp" android:textColor="#9E9E9E"
        android:layout_marginStart="4dp"/>
    <TextView android:id="@+id/tv_chat_text"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:background="#FFFFFF" android:textColor="#212121"
        android:padding="12dp" android:textSize="14sp"
        android:maxWidth="240dp"/>
</LinearLayout>
